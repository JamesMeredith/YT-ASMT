app.get('/api/dashboard', (req, res) => {
  const db = getDbSync();
  const user = req.user;
  const filter = regionFilter.buildRegionFilter(user, 'h');

  // 鏁呴殰缁熻锛堟寜澶у尯/鐪佷唤/鍩庡競杩囨护锛?  const faultStats = db.prepare(`
    SELECT 
      COUNT(*) as total,
      SUM(CASE WHEN status = '寰呭鐞? THEN 1 ELSE 0 END) as pending,
      SUM(CASE WHEN status = '澶勭悊涓? THEN 1 ELSE 0 END) as processing,
      SUM(CASE WHEN status = '寰呭鏍? THEN 1 ELSE 0 END) as review,
      SUM(CASE WHEN status = '宸查棴鐜? THEN 1 ELSE 0 END) as closed,
      SUM(CASE WHEN fault_level = '閲嶅ぇ' AND status != '宸查棴鐜? THEN 1 ELSE 0 END) as major_pending,
      SUM(CASE WHEN fault_level = '绱ф€? AND status != '宸查棴鐜? THEN 1 ELSE 0 END) as urgent_pending
    FROM fault_orders f
    LEFT JOIN hospitals h ON f.hospital_id = h.id
    WHERE 1=1 ${filter.sql}
  `).get(...filter.params);

  // 璁惧缁熻锛堟寜澶у尯/鐪佷唤/鍩庡競杩囨护锛?  const deviceStats = db.prepare(`
    SELECT 
      COUNT(*) as total,
      SUM(CASE WHEN d.status = '鍦ㄧ嚎' THEN 1 ELSE 0 END) as online,
      SUM(CASE WHEN d.status = '绂荤嚎' THEN 1 ELSE 0 END) as offline,
      SUM(CASE WHEN d.status = '缁翠慨涓? THEN 1 ELSE 0 END) as maintenance,
      SUM(CASE WHEN d.status = '宸叉姤搴? THEN 1 ELSE 0 END) as scrapped
    FROM devices d
    LEFT JOIN hospitals h ON d.hospital_id = h.id
    WHERE 1=1 ${filter.sql}
  `).get(...filter.params);

  // 寰呭贰妫€锛堟湰浜烘垨涓嬬骇鑼冨洿锛?  let inspFilter = '';
  let inspParams = [];
  if (user.role === 'provincial_agent' || user.role === 'city_agent') {
    // 浠ｇ悊浜虹湅涓嬪睘宸ョ▼甯堢殑宸℃
    const visFilter = regionFilter.buildUserVisibilityFilter(user, db);
    inspFilter = visFilter.sql.replace(/u\.id/g, 'ip.responsible_engineer_id').replace(/^ AND /, ' AND ');
    inspParams = visFilter.params;
  } else if (user.role === 'engineer') {
    inspFilter = ' AND ip.responsible_engineer_id = ?';
    inspParams = [user.id];
  }
  const pendingInspection = db.prepare(`
    SELECT COUNT(*) as cnt FROM inspection_plans ip
    WHERE ip.next_inspection_date <= date('now','localtime','+3 days')
    AND ip.status = '杩涜涓? ${inspFilter}
  `).get(...inspParams).cnt;

  // 寰呭洖璁匡紙鎸夊湴鍖鸿繃婊わ級
  const pendingFeedback = db.prepare(`
    SELECT COUNT(*) as cnt FROM fault_orders f
    LEFT JOIN hospitals h ON f.hospital_id = h.id
    WHERE f.closed_at >= datetime('now','localtime','-7 days')
    AND f.feedback_completed = 0 AND 1=1 ${filter.sql}
  `).get(...filter.params).cnt;

  // 鏈娑堟伅
  const unreadNotify = db.prepare('SELECT COUNT(*) as cnt FROM notifications WHERE target_user_id = ? AND is_read = 0').get(user.id).cnt;

  // 杩?鏃ユ晠闅滆秼鍔匡紙鎸夊湴鍖鸿繃婊わ級
  const recentFaults = db.prepare(`
    SELECT date(f.created_at) as date, COUNT(*) as cnt
    FROM fault_orders f
    LEFT JOIN hospitals h ON f.hospital_id = h.id
    WHERE f.created_at >= datetime('now','localtime','-7 days') AND 1=1 ${filter.sql}
    GROUP BY date(f.created_at)
    ORDER BY date ASC
  `).all(...filter.params);

  res.json({
    fault: faultStats,
    device: deviceStats,
    pending_inspection: pendingInspection,
    pending_feedback: pendingFeedback,
    unread_notifications: unreadNotify,
    recent_faults: recentFaults
  });
});

